# Database connection URL (used by Prisma locally)
# For local development outside docker, you might use: postgresql://flat_ledger_user:flat_ledger_password@localhost:5400/flat_ledger?schema=public
DATABASE_URL="postgresql://flat_ledger_user:flat_ledger_password@localhost:5400/flat_ledger?schema=public"

# JWT Secret for authentication
JWT_SECRET="super_secret_flat_ledger_token_secret"

# Google Gemini API key (obtain from Google AI Studio at https://aistudio.google.com/)
GEMINI_API_KEY="your-gemini-api-key-here"

# Port for backend server
PORT=5000
